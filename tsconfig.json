{
	"compilerOptions": {
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "esnext",
		"outDir": "./dist",
		"lib": ["esnext"],
		"types": ["node"],
		"sourceMap": true,
		"strict": true,
		"esModuleInterop": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts","*.ts"],
	"exclude": ["node_modules", "dist"]
}
